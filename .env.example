# ========================
# Microsoft Graph / Azure
# ========================
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
GRAPH_WEBHOOK_NOTIFICATION_URL=https://your-domain.com/webhooks/outlook

# ========================
# Database (PostgreSQL)
# ========================
POSTGRES_USER=patent
POSTGRES_PASSWORD=patent_secret
POSTGRES_DB=patent_mail
DATABASE_URL=postgresql+asyncpg://patent:patent_secret@localhost:5432/patent_mail
DATABASE_URL_SYNC=postgresql://patent:patent_secret@localhost:5432/patent_mail

# ========================
# Redis (Queue / Cache)
# ========================
REDIS_URL=redis://localhost:6379

# ========================
# AI (Claude API)
# ========================
ANTHROPIC_API_KEY=

# Azure OpenAI (Claude 대신 사용 시)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=

# ========================
# App
# ========================
APP_ENV=development
SECRET_KEY=change-me-to-a-long-random-string
ALLOWED_ORIGINS=http://localhost:3000

# ========================
# Celery
# ========================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
